<% layout('layouts/boilerplate') %>
    <div class="row">
        <div class="col border-bottom pb-1 mb-3">
            <h1 class="display-3 mb-0"><%= motel.title %></h1>
            <div class="ms-2">
                <h4 class="h5"><%= motel.location %></h4>
            </div>     
        </div>
    </div>    
    <div class="row">
        <div class="col-lg-4 col-12">
            <img src="<%= motel.image %>" alt="<%= motel.title %>" class="img-fluid rounded">
        </div>
        <div class="col-lg-8 col-12 d-flex flex-column">
            <div class="mb-5">
                <p class="lead"><%= motel.description %></p>
            </div>
            <div class="mb-3">
                <span><strong>Price:</strong> $<%= motel.price %>/night</span>
            </div>

            <div class="mt-auto">
                <a class="btn btn-success" href="/motels/<%= motel._id %>/edit">Edit</a>
                <form class="d-inline" method="post" action="/motels/<%= motel._id %>?_method=DELETE">
                    <button class="btn btn-danger">Delete</button>
                </form>
            </div>

        </div>
    </div>
    <div class="row mt-5 pt-4 border-top g-4">
    
        <div class="col-lg-8 col-12">
            <h3 class="h4 mb-4 fw-bold">Guest Reviews</h3>
        
            <div class="reviews-feed-container">
            <% if (motel.reviews.length === 0) { %>
                <p class="text-muted small italic">No reviews yet. Be the first to share your thoughts!</p>
            <% } else { %>
                <% for(let i = motel.reviews.length - 1; i >= 0; i--) { %>
                    <% let review = motel.reviews[i]; %>
                <div class="d-flex align-items-start p-3 mb-3 bg-body-tertiary rounded shadow-sm text-body position-relative">
                        
                    <form action="/motels/<%= motel._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="position-absolute top-0 end-0 p-2">
                        <button type="submit" class="btn-close small display-hover-red" aria-label="Delete Review" style="font-size: 0.75rem; transition: background-color 0.2s;"></button>
                    </form>
                        
                    <div class="d-flex align-items-center justify-content-center bg-warning text-dark font-monospace rounded fw-bold shadow-sm me-3 text-center" style="width: 50px; height: 50px; min-width: 50px; font-size: 1.25rem; line-height: 1;">
                        <%= review.rating %>
                    </div>
                        
                    <div class="flex-grow-1 border-start ps-3 border-secondary-subtle d-flex flex-column justify-content-between">
                        <div class="mb-2 pe-4">
                            <span class="fw-semibold small d-block">Anonymous Guest</span>
                        </div>
                        <p class="card-text mb-3 text-secondary-emphasis" style="font-size: 0.95rem; line-height: 1.4;">
                            <%= review.body %>
                        </p>
                        <div class="text-end mt-auto">
                            <small class="text-muted" style="font-size: 0.75rem;">Verified Stay</small>
                        </div>
                    </div>

                </div>
                <% } %>
            <% } %>
        </div>
    </div>

    <div class="col-lg-4 col-12 align-self-start sticky-top pt-2" style="top: 90px; z-index: 1020;">
        <div class="p-4 bg-body-tertiary rounded shadow-sm">
            <h3 class="h4 mb-4 fw-bold">Leave a Review</h3>
            
            <form action="/motels/<%= motel._id %>/reviews" method="POST" novalidate class="needs-validation">
                
                <div class="mb-3">
                    <label class="form-label fw-bold" for="body">Review</label>
                    <div class="has-validation">
                        <textarea class="form-control" name="review[body]" id="body" rows="5" placeholder="Tell us about your stay..." required></textarea>
                        <div class="invalid-feedback">Please provide some review text.</div>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-bold" for="rating">Rating</label>
                    <input class="form-range" type="range" name="review[rating]" id="rating" min="0" max="5" step="1" value="0">
                    <div class="d-flex justify-content-between px-1 text-muted small">
                        <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
                    </div>
                </div>
                
                <button class="btn btn-success w-100">Submit Review</button>
            </form>
        </div>
    </div>

    </div>
    <% block('scripts').append('<script script src="/js/formValidation.js"></script>') %>
    