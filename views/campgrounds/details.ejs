<% layout('layouts/boilerplate') %>
    <div class="row">
        <div class="col border-bottom pb-1 mb-3">
            <h1 class="display-3 mb-0"><%= campground.title %></h1>
            <div class="ms-2">
                <h4 class="h5"><%= campground.location %></h4>
            </div>     
        </div>
    </div>    
    <div class="row">
        <div class="col-lg-4 col-12">
            <img src="<%= campground.image %>" alt="<%= campground.title %>" class="img-fluid rounded">
        </div>
        <div class="col-lg-8 col-12">
            <div class="mb-5">
                <p class="lead"><%= campground.description %></p>
            </div>
            <div class="mb-3">
                <span><strong>Price:</strong> $<%= campground.price %>/night</span>
            </div>
        </div>

    </div>
    <div class="row mt-4">
        <div class="col">
            <a class="btn btn-success" href="<%= `/campgrounds/${campground.id}/edit` %>">Edit</a>
            <form class="d-inline" method="post" action="<%= `/campgrounds/${campground.id}?_method=DELETE` %>">
                <button class="btn btn-danger">Delete</button>
            </form>
        </div>    
    </div>

