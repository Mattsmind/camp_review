<% layout('layouts/boilerplate') %>
    <div class="col-lg-6 offset-lg-3 col-md-8 offset-md-2 col-sm-12">
        <h1 class="h1 border-bottom pb-1 mb-3">Edit <%= campground.title %></h1>
        
        <form action="<%= `/campgrounds/${campground._id}?_method=PUT` %>" method="post">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" class="form-control" id="title" name="campground[title]" value="<%= campground.title %>">
            </div>
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input type="text" class="form-control" name="campground[location]" id="location" value="<%= campground.location %>">
            </div>
            <div class="mb-3">
                <label for="image" class="form-label">Image URL</label>
                <input type="text" class="form-control" name="campground[image]" id="image" value="<%= campground.image %>">    
            </div>
            <div class="mb-3">
                <label for="price" class="form-label">Price</label>
                <input type="number" class="form-control" name="campground[price]" id="price" step="any" value="<%= campground.price %>">
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" name="campground[description]" id="description" rows="7" style="resize: none;"><%= campground.description %></textarea>
            </div>

            <div class="row mt-3">
                <div class="col-md-6">
                    <button class="btn btn-success form-control">Submit Edits</button>
                </div>
                <div class="col-md-6">
                    <a href="/campgrounds" class="btn btn-danger form-control">Cancel</a>
                </div>       
            </div>  
        </form>
    </div>    
   