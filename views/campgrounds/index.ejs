<% layout('layouts/boilerplate') %>
    <h1 class="display-1 border-bottom pb-1 mb-3"><%= pageTitle %></h1>
    
    <div class="row">
    <% for (let campground of campgrounds) { %>
        <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3 mb-3">
            <div class="card h-100">
                <img src="<%= campground.image %>" class="card-img-top" alt="<%= campground.title %>">
                <div class="card-body d-flex flex-column">
                    <h4 class="card-title h5 fw-lighter border-bottom"><%= campground.title %></h4>
                    <p class="card-text text-clamp mb-3"><%= campground.description %></p>
                    <a href="<%= `/campgrounds/${campground._id}` %>" class="btn btn-success mt-auto">Visit</a>
                </div>
            </div>
        </div>
    <% } %>    
    </div>